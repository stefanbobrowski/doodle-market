{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true, // For importing JSON files like seed.json
    "noEmit": true // Ensure it compiles to JS
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
